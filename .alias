# this file call by ~/.zshrc

#normal alias/comand
alias so="source"
alias vim="nvim"
alias cl="clear"
alias c="claude"
alias cc="claude --continue"
alias oll="ollama"

alias lz="lazygit"

alias ff="ls | grep"
alias yy="yarn"
alias yyt="yarn test"
alias yyd="yarn start:dev"
alias yys="yarn start"

alias nn="npm"
alias nnt="npm run test"
alias nnd="npm run start:dev"
alias nns="npm run start"

# git
alias g="git"

# tmux
alias tm="tmux"
alias tma="tmux attach-session -t"
alias tmd="tmux kill-session -t"
alias tmc="tmux new -s"

# cat
alias hvim="cat ~/.config/cat/vim.help"

# qmk
alias aqmk="cp -X ./.build/dztech_dz60rgb_wkl_v2_1_pinpongTp.bin /Volumes/KBDFANS\ \ /FLASH.BIN"

# Modern CLI replacements
alias ls="eza"
alias ll="eza -la"
alias l="eza -1"
alias tree="eza -T"
alias cat="bat"
